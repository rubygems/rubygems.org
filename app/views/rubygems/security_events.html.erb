<% @title = @rubygem.name %>
<% @title_url = rubygem_path(@rubygem.slug) %>
<% @subtitle = @latest_version&.slug %>

<% if @latest_version %>
  <% content_for :subject do %>
    <%= render "rubygems/aside" %>
  <% end %>

  <% content_for :subject_secondary do %>
    <%= render "rubygems/aside_secondary" %>
  <% end %>
<% end %>

<div class="flex flex-col gap-8 pb-16 lg:pt-10 text-neutral-800 dark:text-neutral-200">
  <div>
    <h1 class="text-h4 font-semibold text-neutral-900 dark:text-white"><%= t(".title") %></h1>
    <p class="text-b2 mt-2">
      <%= t(".description_html", gem: link_to(@rubygem.name, rubygem_path(@rubygem.slug), class: "text-orange-500 hover:text-orange-600")) %>
    </p>
  </div>

  <%= render Events::TableComponent.new(security_events: @security_events) %>
</div>
