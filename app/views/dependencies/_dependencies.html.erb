<% if dependencies.key?(scope) %>
  <div id="<%= gem_name+scope %>"><span class="scope <%= "scope--expanded" if scope == "runtime" %>"><%= scope.titlecase %> :</span>
  <div class="deps_scope <%= "deps_toggle" if scope == "development" %>">
  <% dependencies[scope].each do |name,version,req| %>
    <ul class="deps">
      <li>
        <span>
          <% if version %>
            <%= tag.span(class: "deps_expanded deps_expanded-link", data: { gem_id: name, version: }) {} %>
          <% end %>
        </span>
        <% if version %>
          <%= link_to "/gems/#{name}/versions/#{version}", target: :_blank do %>
            <span class="deps_item"><%= name %> <%= version %>
            <span class="deps_item--details"> <%= req %></span></span>
          <% end %>
        <% else %>
          <span class="deps_item deps_item--unresolved"><%= name %>
          <span class="deps_item--details"> <%= req %></span></span>
        <% end %>

        <div><div class="deps_scope"></div></div>
        <div><div class="deps_scope"></div></div>
      </li>
    </ul>
  <% end %>
</div>
</div>
<% end %>
