<%= form_tag rubygem_reverse_dependencies_path(rubygem_id: rubygem.slug), id: "rdeps-search", method: :get do %>
  <%= label_tag :rdeps_query do %>
    <span class="sr-only"><%= t('.search_reverse_dependencies_html') %></span>
  <% end %>
  <div class="flex gap-3">
    <%= search_field_tag :rdeps_query, params[:rdeps_query],
      placeholder: t('.search_reverse_dependencies_html'),
      class: "flex-1 text-b2 rounded-lg dark:bg-neutral-950 focus:ring-inset focus:ring-1 focus:ring-orange-500" %>
    <%= submit_tag "⌕", id: "rdeps_search_submit", name: nil,
      class: "px-4 rounded-lg bg-orange-500 text-white text-xl hover:bg-orange-600 active:bg-orange-700 transition-colors cursor-pointer" %>
  </div>
<% end %>
