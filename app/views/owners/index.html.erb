<% @title = @rubygem.name %>
<% @subtitle = t(".info", gem: @rubygem.name) %>
<% @roles = Ownership.roles.map { |k,_| [Ownership.human_attribute_name("role.#{k}"), k] } %>

<% add_breadcrumb @rubygem.name, rubygem_path(@rubygem.slug) %>
<% add_breadcrumb t(".title") %>

<h1 class="text-h2 mb-2"><%= @rubygem.name %></h1>
<p class="text-b2 text-neutral-700 dark:text-neutral-300 mb-10"><%= @subtitle %></p>

<%= render CardComponent.new do |c| %>
  <%= c.head(class: "border-b border-neutral-200 dark:border-neutral-800") do %>
    <%= c.section_title t(".title"), icon: "gems", count: @ownerships.size %>
  <% end %>

  <div class="my-8">
    <%= render "owners_table" %>
  </div>

  <% if can_add_owner?(@rubygem) %>
    <%
      label_class = "block text-b4 font-semibold text-neutral-800 dark:text-neutral-200 mb-2"
      field_class = "block w-full rounded border border-neutral-300 dark:border-neutral-600 " \
                    "bg-white dark:bg-neutral-900 text-neutral-900 dark:text-white px-4 h-12 " \
                    "rounded-lg transition" \
                    "outline-none focus:border-orange-500 focus:ring-2 focus:ring-orange-500"
    %>
    <section class="mt-10 border-t border-neutral-200 pt-8 dark:border-neutral-800">
      <h2 class="text-h4 mb-6"><%= t(".add_owner") %></h2>

      <%= form_tag rubygem_owners_path, method: :post, class: "flex flex-col gap-6", id: "new_ownership" do %>
        <div>
          <%= label_tag :handle, t(".email_field"), class: label_class %>
          <%= text_field_tag :handle, nil, class: field_class, required: true %>
        </div>
        <div>
          <%= label_tag :role, t(".role_field"), class: label_class %>
          <%= select_tag :role, options_for_select(@roles), class: "#{field_class} appearance-none" %>
        </div>
        <div>
          <%= render ButtonComponent.new(t(".submit_button"), type: :submit, color: :primary) %>
        </div>
      <% end %>
    </section>
  <% end %>
<% end %>
