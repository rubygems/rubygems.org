<% @title = t("advanced_search") %>
<% add_breadcrumb @title %>

<%= render CardComponent.new do |c| %>
  <%= c.head do %>
    <%= c.title t("advanced_search"), icon: "search" %>
  <% end %>

  <div role="search" data-controller="search">
    <%= form_tag search_url, id: "advanced-search", method: :get do %>

      <div class="flex gap-3 mb-8">
        <%= label_tag :advanced_query do %>
          <span class="sr-only"><%= t("layouts.application.header.search_gem_html") %></span>
        <% end %>
        <%= search_field_tag(
          :query,
          params[:query],
          placeholder: t("layouts.application.header.search_gem_html"),
          autofocus: current_page?(root_url),
          id: "advanced_query",
          class: "flex-1 text-b2 rounded-lg dark:bg-neutral-950 focus:ring-inset focus:ring-1 focus:ring-orange-500",
          data: { search_target: "query" }
        ) %>
        <%= button_tag type: :submit, id: "advanced_search_submit", name: nil,
          aria: { label: t("advanced_search") },
          class: "inline-flex items-center px-4 rounded-lg bg-orange-500 text-white hover:bg-orange-600 active:bg-orange-700 transition-colors cursor-pointer" do %>
          <%= icon_tag "search", class: "h-6 w-6" %>
        <% end %>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        <div>
          <%= label_tag :name, t(".name"), class: "block text-b2 font-semibold mb-2" %>
          <%= text_field_tag :name, "", placeholder: "active OR action",
            class: "w-full text-b2 rounded-lg dark:bg-neutral-950 focus:ring-inset focus:ring-1 focus:ring-orange-500",
            data: { search_target: "attribute", action: "input->search#input keydown.enter->search#submit" } %>
        </div>

        <div>
          <%= label_tag :summary, t(".summary"), class: "block text-b2 font-semibold mb-2" %>
          <%= text_field_tag :summary, "", placeholder: "ORM, NoSQL",
            class: "w-full text-b2 rounded-lg dark:bg-neutral-950 focus:ring-inset focus:ring-1 focus:ring-orange-500",
            data: { search_target: "attribute", action: "input->search#input keydown.enter->search#submit" } %>
        </div>

        <div>
          <%= label_tag :description, t(".description"), class: "block text-b2 font-semibold mb-2" %>
          <%= text_field_tag :description, "", placeholder: "associations AND validations",
            class: "w-full text-b2 rounded-lg dark:bg-neutral-950 focus:ring-inset focus:ring-1 focus:ring-orange-500",
            data: { search_target: "attribute", action: "input->search#input keydown.enter->search#submit" } %>
        </div>

        <div>
          <%= label_tag :downloads, t(".downloads"), class: "block text-b2 font-semibold mb-2" %>
          <%= text_field_tag :downloads, "", placeholder: ">20000",
            class: "w-full text-b2 rounded-lg dark:bg-neutral-950 focus:ring-inset focus:ring-1 focus:ring-orange-500",
            pattern: "\\s*(<=?|>=?)?[\\d]+\\s*",
            data: { search_target: "attribute", action: "input->search#input keydown.enter->search#submit" } %>
        </div>

        <div>
          <%= label_tag :updated, t(".updated"), class: "block text-b2 font-semibold mb-2" %>
          <%= text_field_tag :updated, "", placeholder: ">#{1.week.ago.strftime('%F')}",
            class: "w-full text-b2 rounded-lg dark:bg-neutral-950 focus:ring-inset focus:ring-1 focus:ring-orange-500",
            pattern: "\\s*(<=?|>=?)?[\\d-]+\\s*",
            data: { search_target: "attribute", action: "input->search#input keydown.enter->search#submit" } %>
        </div>
      </div>

      <div class="flex mt-10 pt-6 border-t border-neutral-200 dark:border-neutral-800">
        <%= render ButtonComponent.new(t("advanced_search"), type: :submit) %>
      </div>

    <% end %>
  </div>
<% end %>
