<%# Tailwind/hammy pagination theme. Use with: paginate @collection, theme: "hammy" -%>
<%= paginator.render do -%>
  <nav class="flex flex-wrap items-center justify-center gap-1 my-8" role="navigation" aria-label="Pagination">
    <%= first_page_tag -%>
    <%= prev_page_tag -%>
    <% each_page do |page| -%>
      <% if page.left_outer? || page.right_outer? || page.inside_window? -%>
        <%= page_tag page -%>
      <% elsif !page.was_truncated? -%>
        <%= gap_tag -%>
      <% end -%>
    <% end -%>
    <%= next_page_tag -%>
    <%= last_page_tag -%>
  </nav>
<% end -%>
