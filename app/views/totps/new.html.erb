<% @title = t('.title') %>
<% add_breadcrumb @title %>

<div class="flex items-center justify-center">
  <div class="max-w-lg w-full bg-white dark:bg-black border border-neutral-200 dark:border-neutral-800 rounded-xl shadow-md p-10">
    <h1 class="text-xl font-semibold text-neutral-900 dark:text-white mb-6"><%= t(".title") %></h1>

    <div class="flex justify-center mb-6">
      <%= @qrcode_svg %>
    </div>

    <p class="text-b2 text-neutral-700 dark:text-neutral-300 mb-4"><%= t('.scan_prompt') %></p>

    <div class="text-b2 text-neutral-700 dark:text-neutral-300 mb-8 space-y-1">
      <p><%= t('.account', account: "#{issuer}:#{current_user.email}") %></p>
      <p id="otp-key"><%= t('.key', key: @seed.chars.each_slice(4).map(&:join).join(' ')) %></p>
      <p><%= t('.time_based') %></p>
    </div>

    <%= form_with url: totp_path, method: :post do |form| %>
      <div class="mb-8">
        <%= form.label :otp, 'OTP code',
          class: "block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-2" %>
        <p class="text-b3 text-neutral-600 dark:text-neutral-400 mb-2"><%= t('.otp_prompt') %></p>
        <%= form.text_field :otp,
          autocomplete: 'one-time-code',
          class: "w-full px-4 py-3 border border-neutral-300 dark:border-neutral-600 rounded-lg bg-white dark:bg-neutral-900 text-neutral-900 dark:text-white focus:ring-2 focus:ring-orange-500 focus:border-orange-500 outline-none transition" %>
      </div>
      <%= render ButtonComponent.new(t('.enable'), type: :submit, color: :primary) %>
    <% end %>
  </div>
</div>
