<% @title = t('.title') %>

<h1 class="text-xl font-semibold text-neutral-900 dark:text-white mb-6"><%= t('.title') %></h1>

<% if @only_owner_gems.any? %>
  <div>
    <p><%= (t '.list_only_owner_html', command_link: link_to('gem owner', 'https://guides.rubygems.org/command-reference/#gem-owner')) %></p>
  </div>
  <div id="profile">
    <div>
      <ul>
        <%= render partial: 'rubygem', collection: @only_owner_gems, locals: {owners: true}  %>
      </ul>
    </div>
  </div>
<% end %>

<% if @multi_owner_gems.any? %>
  <div>
    <p><%= t '.list_multi_owner' %></p>
  </div>
  <div id="profile">
    <div>
      <ul>
        <%= render partial: 'rubygem', collection: @multi_owner_gems, locals: {owners: true}  %>
      </ul>
    </div>
  </div>
<% end %>

<div>
  <p><%= t '.instructions' %></p>
  <%= form_for current_user, url: destroy_profile_path, method: :delete do |form| %>
    <div>
      <%= form.label :password, t("activerecord.attributes.user.password") %>
      <%= form.password_field :password, autocomplete: 'current-password' %>
    </div>
    <%= form.submit t('.confirm'), data: { confirm: "This action can't be UNDONE! Are you sure?" } %>
  <% end %>
</div>
